{
  "name": "dewtime",
  "private": true,
  "version": "1.0.0-beta.6",
  "description": "DewTime — Electron + TypeScript desktop time tracking widget",
  "author": "DewDev LLC",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.mjs",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "dev:no-sandbox": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "build:win:native": "electron-vite build && electron-builder --win --publish=never",
    "build:linux": "electron-vite build && electron-builder --linux AppImage --publish=never",
    "test": "npm rebuild better-sqlite3 --build-from-source && vitest run --config vitest.main.config.ts",
    "test:watch": "vitest --config vitest.main.config.ts",
    "smoke:packaged": "electron-rebuild -f -w better-sqlite3 && tsx scripts/smoke-packaged.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test:run": "vitest run --config vitest.main.config.ts && vitest run --config vitest.renderer.config.ts",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "12.9.0",
    "cmdk": "1.1.1",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.8.3",
    "react": "^18.3.0",
    "react-day-picker": "8.10.2",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@playwright/test": "1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "38.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
